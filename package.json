{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "typecheck": "tsc --noEmit",
        "format:fe": "prettier --write .",
        "format:check:fe": "prettier --check .",
        "lint:fe": "npm run format:fe && eslint .",
        "lint:be": "docker compose exec -T app vendor/bin/pint --dirty --format agent",
        "lint": "npm run lint:fe && npm run lint:be"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^9.0.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.6.0",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.100.10",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    }
}
